rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny for arbitrary collections
    match /{document=**} {
      allow read, write: if false;
    }

    // อนุญาตแชร์ข้อมูลและบันทึกร่วมกันข้ามอุปกรณ์ รองรับระบบล็อกอินเลี่ยงสิทธิ์ (Bypass) และ Google Account สดลื่นไหล
    match /records/{date} {
      allow read, write: if true;
    }

    match /settings/{docId} {
      allow read, write: if true;
    }

    match /transactions/{transactionId} {
      allow read, write: if true;
    }
  }
}
